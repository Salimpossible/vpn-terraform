# IMPORTANT: Copy this file to terraform.tfvars and fill in your actual values.
# DO NOT commit terraform.tfvars to version control!

# Your IP address in CIDR notation (e.g., 203.0.113.42/32)
# Find your IP: curl https://ifconfig.me
allowed_ssh_cidr = "203.0.113.42/32"

# AWS region (default: eu-west-3 = Paris, good for privacy)
# Other options: eu-central-1 (Frankfurt), eu-north-1 (Stockholm), sa-east-1 (São Paulo)
aws_region = "eu-west-3"

# EC2 instance type (default: t3.micro = free tier eligible)
instance_type = "t3.micro"

# Project name for resource naming and tagging
project_name = "wg-vpn"

# Path to your SSH public key (will be read from local filesystem)
# Default expands to ~/.ssh/id_ed25519.pub
ssh_public_key_path = "~/.ssh/id_ed25519.pub"

# WireGuard server private key (SENSITIVE)
# Generate locally before applying:
#   wg genkey > server_private.key
# Then copy the contents below (keep on one line)
wg_server_private_key = "PASTE_SERVER_PRIVATE_KEY_HERE"

# WireGuard client public key (SENSITIVE)
# Generate locally before applying:
#   wg genkey | tee client_private.key | wg pubkey > client_public.key
# Then copy the public key contents below (keep on one line)
wg_client_public_key = "PASTE_CLIENT_PUBLIC_KEY_HERE"

# WireGuard server port
wg_server_port = 51820

# WireGuard client allowed IP (tunnel address for your client)
wg_client_allowed_ip = "10.0.100.2/32"
